# Gustavo Pedrosa FX - Backend Production Environment
# Copie para .env.production e ajuste os valores

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:hub123nexusai@postgres:5432/saas_gerenciamento_fx

# JWT - gere com: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Internal API (n8n integration)
INTERNAL_API_KEY=generate-strong-api-key-for-n8n
N8N_WEBHOOK_URL=https://n8n.hubnexusai.com/webhook/gpfx-sync

# OpenAI - IA do Trade
OPENAI_API_KEY=sk-proj-sua-chave-openai-aqui

# MinIO (S3-compatível) - screenshots por trade
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=gpfx-minio-user
MINIO_SECRET_KEY=gpfx-minio-senha-segura
MINIO_BUCKET_SCREENSHOTS=gpfx-screenshots
MINIO_SECURE=false
MINIO_PUBLIC_URL=https://minio.hubnexusai.com

# Redis Cache
REDIS_URL=redis://redis:6379/5

# CORS - origens permitidas (separadas por vírgula se precisar)
CORS_ORIGINS=https://fx.hubnexusai.com,https://api.hubnexusai.com

# Crypto - chave para criptografar credenciais de corretora (32+ caracteres)
BROKER_CREDENTIALS_KEY=change-me-32-bytes-base64-encoded

# Environment
ENVIRONMENT=production
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# File Upload Limits
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,csv,txt

# Session Management
SESSION_TIMEOUT=3600  # 1 hour in seconds
MAX_CONCURRENT_SESSIONS=10

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# External Services
EXTERNAL_API_TIMEOUT=30
NOTIFICATION_SERVICE_URL=https://notifications.hubnexusai.com

# Feature Flags
ENABLE_AI=true
ENABLE_REPLAY=true
ENABLE_BROKER_SYNC=true
ENABLE_EXPORT=true
ENABLE_NOTIFICATIONS=true
