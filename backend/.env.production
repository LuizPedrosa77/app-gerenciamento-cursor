# Gustavo Pedrosa FX - Backend Production Environment
# Configurações para deploy em produção na VPS

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:hub123nexusai@postgres:5432/saas_gerenciamento_fx

# JWT - gere com: openssl rand -hex 32
SECRET_KEY=gpfx-secret-key-2026-mude-em-producao

# Internal API (n8n integration)
INTERNAL_API_KEY=gpfx-internal-2026-mude-em-producao
N8N_WEBHOOK_URL=https://n8n.hubnexusai.com/webhook-test/saasgerenciamento

# OpenAI - IA do Trade
OPENAI_API_KEY=COLOCAR_SUA_CHAVE_AQUI

# MinIO (S3-compatível) - screenshots por trade
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=gpfx-minio-user
MINIO_SECRET_KEY=gpfx-minio-senha-2026
MINIO_BUCKET_SCREENSHOTS=gpfx-screenshots
MINIO_SECURE=false
MINIO_PUBLIC_URL=https://minio.hubnexusai.com

# Redis Cache
REDIS_URL=redis://redis:6379/5

# Frontend URLs (para CORS)
VITE_API_URL=https://api.hubnexusai.com
VITE_WS_URL=wss://api.hubnexusai.com

# CORS - origens permitidas
CORS_ORIGINS=https://fx.hubnexusai.com,https://api.hubnexusai.com

# Crypto - chave para criptografar credenciais de corretora (32+ caracteres)
BROKER_CREDENTIALS_KEY=gpfx-encryption-key-2026-change-me

# Environment
ENVIRONMENT=production
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# File Upload Limits
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,csv,txt

# Session Management
SESSION_TIMEOUT=3600  # 1 hour in seconds
MAX_CONCURRENT_SESSIONS=10

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# External Services
EXTERNAL_API_TIMEOUT=30
NOTIFICATION_SERVICE_URL=https://notifications.hubnexusai.com

# Feature Flags
ENABLE_AI=true
ENABLE_REPLAY=true
ENABLE_BROKER_SYNC=true
ENABLE_EXPORT=true
ENABLE_NOTIFICATIONS=true
